// =============== co2 emmision notification============
function showNotification(message, type = "safe") {
  const box = document.getElementById("notification");

  box.innerText = message;
  box.className = "notification show " + type;

  setTimeout(() => {
    box.classList.remove("show");
  }, 5000);
}
