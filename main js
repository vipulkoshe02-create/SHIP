};

window.addEventListener("click", (event) => {

  mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
  mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;

  raycaster.setFromCamera(mouse, camera);

  if (!ship) return;

  const intersects = raycaster.intersectObject(ship, true);

  if (intersects.length > 0) {

    const clicked = intersects[0].object;

    // ✅ Propeller click (keep this working)
    if (
      propeller &&
      (clicked === propeller || propeller.children.includes(clicked))
    ) {
      const temp = getPropellerTemperature();
      const box = document.getElementById("tempBarContainer");
      box.classList.remove("hidden");
      updateTempBar(temp);
      document.getElementById("stackInfo").classList.add("hidden");
      return;
    }

    // ✅ Container stack click
    if (isContainerMode && clicked.name.includes("Stack")) {
      let selectedStack = clicked;
      activeStack = selectedStack;
      // 🔄 Reset all stacks
      containerStacks.forEach(stack => {
        stack.traverse(child => {
          if (child.isMesh && child.material.emissive) {
            child.material.emissive.set(0x000000);
            child.material.emissiveIntensity = 0;
          }
        });
      });

      // // 🎯 Find the correct stack object
      // let selectedStack = clicked;

      const data = stackData[selectedStack.name];

      if (data) {
        document.getElementById("stackInfo").classList.remove("hidden");
        document.getElementById("stackTitle").innerText = selectedStack.name;
        document.getElementById("fillCircle").innerText = data.fill;
        document.getElementById("stackTemp").innerText = data.temp;
        document.getElementById("stackWeight").innerText = data.weight;
        document.getElementById("stackCount").innerText = data.containers;
        document.getElementById("stackStatus").innerText = data.status;

        // 🔵 animate ring
        const percent = parseFloat(data.fill);
        updateRing(percent);

        // 🌈 dynamic color based on status
        const ring = document.querySelector(".ring-fill");

        if (data.status === "Critical") ring.style.stroke = "red";
        else if (data.status === "High Load") ring.style.stroke = "orange";
        else if (data.status === "Moderate") ring.style.stroke = "yellow";
        else ring.style.stroke = "#00eaff";
      }

      // 🎨 Get color
      const color = stackColors[selectedStack.name] || 0xffffff;

      // 🌟 Apply color to entire stack
      selectedStack.traverse(child => {
        if (child.isMesh) {

          // ⚠️ ensure unique material (VERY IMPORTANT)
          child.material = child.material.clone();

          if (!child.material.emissive) {
            child.material.emissive = new THREE.Color(0x000000);
          }

          child.material.emissive.set(color);
          child.material.emissiveIntensity = 1.5;
        }
      });

      console.log("Selected stack:", selectedStack.name);
      return;
    }
  }

  // ❌ Click outside → reset everything
  containerStacks.forEach(stack => {
    stack.traverse(child => {
      if (child.isMesh && child.material.emissive) {
        child.material.emissive.set(0x000000);
        child.material.emissiveIntensity = 0;
      }
    });
  });

  // 🔻 Hide BOTH UI panels
  document.getElementById("tempBarContainer").classList.add("hidden");
  document.getElementById("stackInfo").classList.add("hidden");

});

function getStackTopPosition(obj, camera) {
  const box = new THREE.Box3().setFromObject(obj);
  const top = new THREE.Vector3();

  // get top-center of bounding box
  top.set(
    (box.min.x + box.max.x) / 2,
    box.max.y, // 🔥 TOP
    (box.min.z + box.max.z) / 2
  );

  // project to screen
  top.project(camera);

  return {
    x: (top.x * 0.5 + 0.5) * window.innerWidth,
    y: (-top.y * 0.5 + 0.5) * window.innerHeight
  };
}

// 🔁 Animation
let lastTime = performance.now();

function animate() {
  requestAnimationFrame(animate);

  let currentTime = performance.now();
  let deltaTime = (currentTime - lastTime) / 1000;
  lastTime = currentTime;
  
  const t = Date.now() * 0.001;
  
  
  
  // 🚢 Ship floating
  if (ship) {
    ship.position.y = -2.8 + Math.sin(t * 2) * 0.3;
  }

  updateData();              // update speed first
  Ocean.Update(camera);
  
  if (propeller) {
    const targetSpeed = speedKnots * 1.852
    propellerSpeed = targetSpeed * 1; // increase multiplier for visibility
    propeller.rotation.z += propellerSpeed * deltaTime;
  }
  // 📊 Update data
  
  updateDistance(deltaTime); // update (reduce) distance
  
  checkCarbonAlert();
  
  // 📊 UI update
  document.getElementById("speed").innerText = speedKnots.toFixed(1) + " kn";
  document.getElementById("fuel").innerText = fuel.toFixed(1) + " %";
  document.getElementById("distance").innerText = distanceRemaining.toFixed(2) + " km";
  document.getElementById("ETA").innerText = getETA();
  document.getElementById("co2").innerText = getCO2() + " tons";
  document.getElementById("carbonIndex").innerText = getCarbonIndex().toFixed(2);
  document.getElementById("cargo").innerText = cargoWeight + " tons";
  
  const statusEl = document.getElementById("carbonStatus");
  const status = getCarbonStatus();
  
  
  if (status.includes("Safe")) statusEl.style.color = "green";
  else if (status.includes("Moderate")) statusEl.style.color = "orange";
  else statusEl.style.color = "red";
  
  statusEl.innerText = status;
  
  if (status.includes("Safe")) statusEl.style.color = "green";
  else if (status.includes("Moderate")) statusEl.style.color = "orange";
  else statusEl.style.color = "red";
  
  const box = document.getElementById("tempBarContainer");
  
  if (!box.classList.contains("hidden")) {
    const temp = getPropellerTemperature();
    updateTempBar(temp);
  }
  
  
  const panel = document.getElementById("stackInfo");
  
  if (activeStack && !panel.classList.contains("hidden")) {
    const pos = getStackTopPosition(activeStack, camera);
    // Offset to appear ABOVE + SIDE
    panel.style.left = pos.x + 20 + "px";   // slight right
    panel.style.top = pos.y - 200 + "px";   // above stack
  }
  
  
  controls.update();
  if (Ocean.surface.material.uniforms._Time) {
  Ocean.surface.material.uniforms._Time.value += deltaTime;
}
  
  renderer.render(scene, camera);
}
const TOTAL_DISTANCE = 6100;
let distanceRemaining = TOTAL_DISTANCE;

function updateDistance(deltaTime) {

  const scaledTime = deltaTime * TIME_SCALE;

  const distanceTravelled = speed * scaledTime;

  distanceRemaining -= distanceTravelled;

  if (distanceRemaining < 0) distanceRemaining = 0;

  document.getElementById("distance").innerText =
    distanceRemaining.toFixed(2) + " km";



}
let lastStatus = "";

function checkCarbonAlert() {
  const status = getCarbonStatus();

  if (status !== lastStatus) {
    lastStatus = status;

    if (status.includes("Safe")) {
      showNotification("🟢 Emissions within safe limits", "safe");
    }
    else if (status.includes("Moderate")) {
      showNotification("🟡 Emissions rising — monitor speed", "warn");
    }
    else {
      showNotification("🔴 Carbon limit exceeded! Reduce speed!", "danger");
    }
  }
}

animate();

